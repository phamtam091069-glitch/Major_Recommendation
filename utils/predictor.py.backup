def _normalize_alias_value(text: str) -> str:
    text = _norm_text(text)
    text = text.replace("&", " va ")
    text = text.replace("/", " ")
    text = text.replace("-", " ")
    text = re.sub(r"[^\w\s]", " ", text, flags=re.UNICODE)
    return re.sub(r"\s+", " ", text).strip()


def _generate_major_aliases(major_key: str) -> List[str]:
    aliases = {
        _normalize_alias_value(major_key),
        _normalize_alias_value(MAJOR_DISPLAY.get(major_key, major_key)),
    }
    aliases.update(_normalize_alias_value(alias) for alias in MAJOR_EXTRA_ALIAS_MAP.get(major_key, []))
    aliases.update(_normalize_alias_value(alias) for alias in MARINE_ALIAS_MAP.get(major_key, []))
    return sorted([alias for alias in aliases if alias], key=len, reverse=True)

