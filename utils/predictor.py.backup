def _norm_text(v: Any) -> str:
    text = str(v or "").strip().lower()
    normalized = unicodedata.normalize("NFKD", text)
    return "".join(ch for ch in normalized if not unicodedata.combining(ch))


def _vi_value(field: str, value: str) -> str:
    v = _norm_text(value)
    if not v:
        return ""
    mapped = DISPLAY_VALUE_MAP.get(field, {}).get(v)
    if mapped:
        return mapped
    return value.strip() if str(value).strip() else ""


def _contains_any(text: str, keywords: List[str]) -> bool:
    normalized = _norm_text(text)
    return any(keyword in normalized for keyword in keywords)


def generate_feedback(
    student_data: Dict[str, str],
    major: Dict[str, str],
    final_score: float,
    model_score: float,
    criteria_score: float,
) -> str:
    major_name = str(major.get("nganh", "Ngành này"))

    if final_score >= 75:
        ket_luan = f"Bạn có mức phù hợp cao với ngành {major_name}."
    elif final_score >= 55:
        ket_luan = f"Bạn khá phù hợp với ngành {major_name}."
    else:
        ket_luan = f"Ngành {major_name} hiện phù hợp ở mức tham khảo với bạn."

    return ket_luan


class Predictor:
    def __init__(self) -> None:
        self.model = joblib.load(MODEL_RF_PATH)
        self.ohe = joblib.load(MODEL_OHE_PATH)
        # Load tfidf with pickle (protocol 5) for better sparse matrix support
        with open(MODEL_TFIDF_PATH, "rb") as f:
            self.tfidf = pickle.load(f)
        with open(MODEL_MAJORS_PATH, "r", encoding="utf-8") as f:
            self.majors: List[Dict[str, str]] = json.load(f)

        self.major_names = [item["nganh"] for item in self.majors]
        self.major_vectors = self.tfidf.transform([item["mo_ta"] for item in self.majors])
        self.major_lookup = {item["nganh"]: item for item in self.majors}
        self.major_aliases = {major: _generate_major_aliases(major) for major in self.major_names}
        self.major_tokens = {
            item["nganh"]: set(_norm_text(item.get("mo_ta", "")).split()) for item in self.majors
        }

        self.weight_rf = HYBRID_WEIGHT_RF
        self.weight_cosine = HYBRID_WEIGHT_COSINE
        self.model_name = "CalibratedModel"
        if HYBRID_CONFIG_PATH.exists():
            cfg = json.loads(HYBRID_CONFIG_PATH.read_text(encoding="utf-8"))
            self.weight_rf = float(cfg.get("weight_rf", HYBRID_WEIGHT_RF))
            self.weight_cosine = float(cfg.get("weight_cosine", HYBRID_WEIGHT_COSINE))
            self.model_name = str(cfg.get("model", self.model_name))

    def _rule_hints(self, payload: Dict[str, str]) -> Dict[str, float]:
        scores: Dict[str, float] = {}
        mon = _normalize_alias_value(payload.get("mon_hoc_yeu_thich", ""))
        skill = _normalize_alias_value(payload.get("ky_nang_noi_bat", ""))
        interest = _normalize_alias_value(payload.get("so_thich_chinh", ""))
        goal = _normalize_alias_value(payload.get("muc_tieu_nghe_nghiep", ""))
        self_text = _normalize_alias_value(payload.get("mo_ta_ban_than", ""))
        future_text = _normalize_alias_value(payload.get("dinh_huong_tuong_lai", ""))
        combined_text = " ".join(part for part in [self_text, future_text] if part)

        if mon in ["tin hoc", "toan"] and ("phan tich" in skill or "giai quyet" in skill):
            scores["Cong nghe thong tin"] = scores.get("Cong nghe thong tin", 0) + 0.03
            scores["Khoa hoc du lieu"] = scores.get("Khoa hoc du lieu", 0) + 0.04
        if interest == "kinh doanh" and ("giao tiep" in skill or "lanh dao" in skill):
            scores["Quan tri kinh doanh"] = scores.get("Quan tri kinh doanh", 0) + 0.05
        # FIX: Boost all design majors for "nghe thuat" interest
        if interest == "nghe thuat" or "sang tao" in skill:
            scores["Thiet ke do hoa"] = scores.get("Thiet ke do hoa", 0) + 0.12
            scores["Thiet ke noi that"] = scores.get("Thiet ke noi that", 0) + 0.12
            scores["Thiet ke thoi trang"] = scores.get("Thiet ke thoi trang", 0) + 0.10
            scores["My thuat"] = scores.get("My thuat", 0) + 0.10
            scores["Kien truc"] = scores.get("Kien truc", 0) + 0.08
        # FIX: Boost design majors for "theo dam me" (follow passion) goal + "thiet ke" in future text
        if goal == "theo dam me" or "sang tao" in combined_text or "thiet ke" in combined_text:
            scores["Thiet ke do hoa"] = scores.get("Thiet ke do hoa", 0) + 0.16
            scores["Thiet ke noi that"] = scores.get("Thiet ke noi that", 0) + 0.16
            scores["Thiet ke thoi trang"] = scores.get("Thiet ke thoi trang", 0) + 0.14
            scores["My thuat"] = scores.get("My thuat", 0) + 0.12
            scores["Kien truc"] = scores.get("Kien truc", 0) + 0.10

        language_signal = sum(
            [
                1 if interest == "ngon ngu" else 0,
                1 if mon == "anh" else 0,
                1 if skill in ["giao tiep", "thuyet trinh", "lam viec nhom"] else 0,
                1 if _contains_any(
                    combined_text,
                    ["ngoai ngu", "bien phien dich", "phien dich", "dich thuat", "van hoa", "quoc te"],
                ) else 0,
            ]
        )
        if language_signal >= 2:
            for major, boost in LANGUAGE_PROFILE_MAJOR_BOOST.items():
                scores[major] = scores.get(major, 0.0) + boost / 100.0
        elif language_signal == 1 and interest == "ngon ngu":
            for major, boost in LANGUAGE_PROFILE_MAJOR_BOOST.items():
                scores[major] = scores.get(major, 0.0) + (boost * 0.5) / 100.0

        if interest == "ngon ngu" or language_signal >= 1:
            for major, boost in LANGUAGE_PROFILE_MAJOR_BOOST.items():
                scores[major] = scores.get(major, 0.0) + (boost * 0.35) / 100.0
            scores["Bao chi"] = scores.get("Bao chi", 0.0) + 0.02
            scores["Truyen thong da phuong tien"] = scores.get("Truyen thong da phuong tien", 0.0) + 0.015
            scores["Quan he cong chung"] = scores.get("Quan he cong chung", 0.0) + 0.015

        if interest == "ngon ngu":
            for major in ["Ngon ngu Anh", "Ngon ngu Trung", "Ngon ngu Nhat", "Ngon ngu Han"]:
                scores[major] = scores.get(major, 0.0) + 0.15
            if mon == "anh":
                scores["Ngon ngu Anh"] = scores.get("Ngon ngu Anh", 0.0) + 0.10
            if skill in ["giao tiep", "thuyet trinh", "lam viec nhom"]:
                for major in ["Ngon ngu Anh", "Ngon ngu Trung", "Ngon ngu Nhat", "Ngon ngu Han"]:
                    scores[major] = scores.get(major, 0.0) + 0.05
                scores["Bao chi"] = scores.get("Bao chi", 0.0) + 0.03
                scores["Truyen thong da phuong tien"] = scores.get("Truyen thong da phuong tien", 0.0) + 0.025
                scores["Quan he cong chung"] = scores.get("Quan he cong chung", 0.0) + 0.025

        tech_signal = sum(
            [
                1 if interest == "cong nghe" else 0,
                1 if mon in ["toan", "tin hoc"] else 0,
                1 if skill in ["phan tich du lieu", "tu duy logic", "giai quyet van de"] else 0,
                1 if goal in ["phat trien chuyen mon", "thu nhap cao"] else 0,
                1 if _contains_any(combined_text, ["data", "du lieu", "phan tich", "business analyst", "data scientist"]) else 0,
            ]
        )

        # FIX: Only apply TECH boost if there's explicit tech interest (3+ signals)
        # This prevents AI from being boosted for non-tech majors like tourism, arts, etc.
        if tech_signal >= 3:
            for major, boost in TECH_PROFILE_MAJOR_BOOST.items():
                scores[major] = scores.get(major, 0.0) + boost / 100.0

        if _contains_any(combined_text, DATA_SCIENCE_INTENT_KEYWORDS):
            scores["Khoa hoc du lieu"] = scores.get("Khoa hoc du lieu", 0.0) + 0.06

        if interest == "giao duc":
            scores["Su pham Toan hoc"] = scores.get("Su pham Toan hoc", 0.0) + 0.05
            scores["Su pham Tin hoc"] = scores.get("Su pham Tin hoc", 0.0) + 0.05
            scores["Su pham Sinh hoc"] = scores.get("Su pham Sinh hoc", 0.0) + 0.05
            scores["Su pham Hoa hoc"] = scores.get("Su pham Hoa hoc", 0.0) + 0.05
            scores["Su pham Vat ly"] = scores.get("Su pham Vat ly", 0.0) + 0.05
            scores["Su pham Lich su"] = scores.get("Su pham Lich su", 0.0) + 0.05
            scores["Su pham Dia ly"] = scores.get("Su pham Dia ly", 0.0) + 0.05

            subject_major_map = {
                "toan": "Su pham Toan hoc",
                "tin hoc": "Su pham Tin hoc",
                "sinh": "Su pham Sinh hoc",
                "hoa": "Su pham Hoa hoc",
                "ly": "Su pham Vat ly",
                "su": "Su pham Lich su",
                "dia": "Su pham Dia ly",
            }
            target_major = subject_major_map.get(mon)
            if target_major:
                scores[target_major] = scores.get(target_major, 0.0) + 0.18

            if _contains_any(combined_text, ["giao vien", "day hoc", "su pham", "dung lop", "bai giang"]):
                bonus_major = subject_major_map.get(mon)
                if bonus_major:
                    scores[bonus_major] = scores.get(bonus_major, 0.0) + 0.10

        return scores

    def _has_explicit_data_science_intent(self, row: Dict[str, str]) -> bool:
        self_text = _normalize_alias_value(row.get("mo_ta_ban_than", ""))
        future_text = _normalize_alias_value(row.get("dinh_huong_tuong_lai", ""))
        combined_text = " ".join(part for part in [self_text, future_text] if part)
        return _contains_any(combined_text, DATA_SCIENCE_INTENT_KEYWORDS)

    def _field_match_score(self, field: str, value: str, major: str) -> float:
        value_n = _normalize_alias_value(value)
        if not value_n:
            return 0.0

        major_tokens = self.major_tokens.get(major, set())
        field_map = FIELD_TAG_MAP.get(field, {})
        tags = field_map.get(value_n, value_n.split())
        if not tags:
            return 0.0

        hit = sum(1 for t in tags if t in major_tokens)
        return min(1.0, hit / max(1, len(tags)))

    def _criteria_scores(self, row: Dict[str, str]) -> Dict[str, float]:
        # Phan minh bach theo 8 truong input.
        major_text_matrix = self.major_vectors

        txt_self = _norm_text(row.get("mo_ta_ban_than", ""))
        txt_future = _norm_text(row.get("dinh_huong_tuong_lai", ""))
        txt_self_vec = self.tfidf.transform([txt_self]) if txt_self else None
        txt_future_vec = self.tfidf.transform([txt_future]) if txt_future else None

        # FIX: Detect design interest from combined input
        interest = _normalize_alias_value(row.get("so_thich_chinh", ""))
        goal = _normalize_alias_value(row.get("muc_tieu_nghe_nghiep", ""))
        future_text = _normalize_alias_value(row.get("dinh_huong_tuong_lai", ""))
        combined_text = " ".join([txt_self, txt_future]) if (txt_self or txt_future) else ""

        scores: Dict[str, float] = {}
        for idx, major in enumerate(self.major_names):
            s = 0.0
            s += CRITERIA_WEIGHTS["so_thich_chinh"] * self._field_match_score(
                "so_thich_chinh", row.get("so_thich_chinh", ""), major
            )
            s += CRITERIA_WEIGHTS["mon_hoc_yeu_thich"] * self._field_match_score(
                "mon_hoc_yeu_thich", row.get("mon_hoc_yeu_thich", ""), major
            )
            s += CRITERIA_WEIGHTS["ky_nang_noi_bat"] * self._field_match_score(
                "ky_nang_noi_bat", row.get("ky_nang_noi_bat", ""), major
            )
            s += CRITERIA_WEIGHTS["tinh_cach"] * self._field_match_score(
                "tinh_cach", row.get("tinh_cach", ""), major
            )
            s += CRITERIA_WEIGHTS["moi_truong_lam_viec_mong_muon"] * self._field_match_score(
                "moi_truong_lam_viec_mong_muon", row.get("moi_truong_lam_viec_mong_muon", ""), major
            )
            s += CRITERIA_WEIGHTS["muc_tieu_nghe_nghiep"] * self._field_match_score(
                "muc_tieu_nghe_nghiep", row.get("muc_tieu_nghe_nghiep", ""), major
            )

            if txt_self_vec is not None:
                self_sim = float(cosine_similarity(txt_self_vec, major_text_matrix[idx])[0][0])
            else:
                self_sim = 0.0
            if txt_future_vec is not None:
                future_sim = float(cosine_similarity(txt_future_vec, major_text_matrix[idx])[0][0])
            else:
                future_sim = 0.0

            s += CRITERIA_WEIGHTS["mo_ta_ban_than"] * max(0.0, self_sim)
            s += CRITERIA_WEIGHTS["dinh_huong_tuong_lai"] * max(0.0, future_sim)

            # FIX: Boost design majors directly in criteria scores if "nghe thuat" interest
            if interest == "nghe thuat" and major in ["Thiet ke do hoa", "Thiet ke noi that", "Thiet ke thoi trang", "My thuat", "Kien truc"]:
                s += 0.25  # Direct boost in criteria score (0-1 scale, will be x100)
            # FIX: Boost design majors if "theo dam me" goal or "thiet ke" in future text
            if (goal == "theo dam me" or "thiet ke" in combined_text) and major in ["Thiet ke do hoa", "Thiet ke noi that", "Thiet ke thoi trang", "My thuat", "Kien truc"]:
                s += 0.30  # Direct boost for passion-driven students

            scores[major] = max(0.0, min(100.0, s * 100.0))

        return scores

    def _extract_user_personality(self, row: Dict[str, str]) -> Dict[str, float]:
        """
        APPROACH 1: Extract personality traits from user input.
        Returns: {"leadership": 0.0-1.0, "extroverted": 0.0-1.0, ...}
        """
        personality = {
            "leadership": 0.0,
            "extroverted": 0.0,
            "responsibility": 0.0,
            "communication": 0.0,
        }

        # Combine all text inputs
        combined_text = " ".join(
            [
                _norm_text(row.get("ky_nang_noi_bat", "")),
                _norm_text(row.get("tinh_cach", "")),
                _norm_text(row.get("mo_ta_ban_than", "")),
                _norm_text(row.get("dinh_huong_tuong_lai", "")),
            ]
        )

        # Leadership indicators
        if _contains_any(combined_text, ["lanh dao", "chi huy", "quan ly", "huong dan", "chi dao", "cap quan ly"]):
            personality["leadership"] = 0.9

        # Extroverted indicators
        if _contains_any(combined_text, ["huong ngoai", "giao tiep", "xa hoi", "truyen thong", "marketing", "du lich"]):
            personality["extroverted"] = 0.9

        # Responsibility indicators
        if _contains_any(combined_text, ["trach nhiem", "chu dong", "can thi", "suc khoe", "an toan", "uy tin"]):
            personality["responsibility"] = 0.9

        # Communication indicators
        if _contains_any(combined_text, ["giao tiep", "thuyet trinh", "ngon ngu", "lam viec nhom", "ham hoc"]):
            personality["communication"] = 0.9

        return personality

    def _filter_by_personality(
        self,
        ranked_majors: List[tuple],
        user_personality: Dict[str, float],
        threshold: float = 0.5,
    ) -> List[str]:
        """
        APPROACH 1: Filter majors by personality match.
        ranked_majors: List of (major_name, score) tuples
        threshold: How strict to be (0.5 = all 4 traits must match >= threshold average)
        Returns: Filtered list of major names in order
        """
        filtered = []

        for major_name, score in ranked_majors:
            major_reqs = MAJOR_PERSONALITY_REQUIREMENTS.get(major_name, {})

            # Calculate personality match for this major
            match_count = 0
            total_traits = 0

            for trait, user_value in user_personality.items():
                major_requirement = major_reqs.get(trait, 0.5)
                if user_value >= major_requirement:
                    match_count += 1
                total_traits += 1

            match_ratio = match_count / total_traits if total_traits > 0 else 0

            # Keep major if personality match passes threshold
            if match_ratio >= threshold:
                filtered.append(major_name)

        return filtered

    def predict(self, payload: Dict[str, str]) -> Dict[str, Any]:
        row = row_dict_from_payload(payload)
        student_df = pd.DataFrame([{col: row[col] for col in CATEGORICAL_COLS}])
        student_cat = self.ohe.transform(student_df)

        profile = build_profile_text(row)
        student_text = self.tfidf.transform([profile])

        features = hstack([student_cat, student_text])
        ml_probs = self.model.predict_proba(features)[0]
        ml_dict = dict(zip(self.model.classes_, ml_probs))

        content_scores = cosine_similarity(student_text, self.major_vectors)[0]
        content_dict = dict(zip(self.major_names, content_scores))

        rule_boosts = self._rule_hints(payload)
        criteria_scores = self._criteria_scores(row)

        final_scores: Dict[str, float] = {}
        model_raw_scores: Dict[str, float] = {}
        for major in self.major_names:
            base_score = (
                self.weight_rf * ml_dict.get(major, 0.0)
                + self.weight_cosine * content_dict.get(major, 0.0)
            )
            raw_boost = rule_boosts.get(major, 0.0)
            max_boost = HIGH_SIGNAL_RULE_CAP.get(major, min(0.03, max(0.005, base_score * 0.08)))
            applied_boost = min(raw_boost, max_boost)
            model_raw = base_score + applied_boost
            model_raw_scores[major] = model_raw
            rule_boosts[major] = applied_boost

        model_scores: Dict[str, float] = {}
        for major, raw in model_raw_scores.items():
            # Giữ điểm mô hình trên cùng thang xác suất/tương đồng ban đầu để tránh
            # một ngành cao đột biến chỉ vì min-max normalize theo từng request.
            model_scores[major] = max(0.0, min(100.0, raw * 100.0))

        for major in self.major_names:
            final_scores[major] = (
                MODEL_BLEND_WEIGHT * model_scores.get(major, 0.0)
                + CRITERIA_BLEND_WEIGHT * criteria_scores.get(major, 0.0)
            )

        if _normalize_alias_value(row.get("so_thich_chinh", "")) == "ngon ngu":
            for major in ["Ngon ngu Anh", "Ngon ngu Trung", "Ngon ngu Nhat", "Ngon ngu Han"]:
                final_scores[major] = final_scores.get(major, 0.0) + 12.0
            for major in ["Bao chi", "Truyen thong da phuong tien", "Quan he cong chung"]:
                final_scores[major] = final_scores.get(major, 0.0) + 4.0

        if self._has_explicit_data_science_intent(row):
            ranked_now = sorted(final_scores.items(), key=lambda x: x[1], reverse=True)
            ds_score = final_scores.get("Khoa hoc du lieu", 0.0)
            ds_rank = next((idx for idx, (major, _) in enumerate(ranked_now) if major == "Khoa hoc du lieu"), None)
            if ds_rank is not None and ds_rank <= 2:
                top_major, top_score = ranked_now[0]
                gap = top_score - ds_score
                if top_major != "Khoa hoc du lieu" and gap <= DATA_SCIENCE_RERANK_MAX_GAP:
                    final_scores["Khoa hoc du lieu"] = top_score + DATA_SCIENCE_RERANK_MARGIN

        total_final = sum(final_scores.values())
        if total_final > 0:
            relative_scores = {k: (v / total_final) * 100.0 for k, v in final_scores.items()}
        else:
            u = 100.0 / max(1, len(final_scores))
            relative_scores = {k: u for k in final_scores}

        # APPROACH 1: Apply personality filter to remove mismatched majors
        all_ranked = sorted(final_scores.items(), key=lambda x: x[1], reverse=True)
        user_personality = self._extract_user_personality(row)
        
        # Filter with threshold 0.5 first
        filtered_majors_list = self._filter_by_personality(all_ranked, user_personality, threshold=0.5)
        
        # If filter is too strict (< 3 majors), lower threshold to 0.3
        if len(filtered_majors_list) < 3:
            filtered_majors_list = self._filter_by_personality(all_ranked, user_personality, threshold=0.3)
        
        # If still not enough, use top 3 unfiltered (fallback)
        if len(filtered_majors_list) < 3:
            filtered_majors_list = [major for major, _ in all_ranked[:3]]
        
        # Build final top 3 from filtered majors
        ranked = [(major, final_scores[major]) for major in filtered_majors_list[:3]]
        top3: List[Dict[str, float]] = []
        for major, final_score in ranked:
            ml_p = ml_dict.get(major, 0.0)
            cos_p = content_dict.get(major, 0.0)
            major_info = self.major_lookup.get(major, {"nganh": major, "mo_ta": ""})
            feedback = generate_feedback(
                row,
                major_info,
                round(final_score, 2),
                round(model_scores.get(major, 0.0), 2),
                round(criteria_scores.get(major, 0.0), 2),
            )
            top3.append(
                {
                    "nganh": major,
                    "score": round(final_score, 2),
                    "score_display": round(final_score, 2),
                    "score_final": round(final_score, 2),
                    "absolute_score": round(final_score, 2),
                    "score_model": round(model_scores.get(major, 0.0), 2),
                    "score_criteria": round(criteria_scores.get(major, 0.0), 2),
                    "score_relative": round(relative_scores.get(major, 0.0), 2),
                    "raw_score": round(final_score, 6),
                    "phan_hoc_may": round(ml_p * 100, 2),
                    "phan_noi_dung": round(cos_p * 100, 2),
                    "rule_boost": round(rule_boosts.get(major, 0.0), 4),
                    "feedback": feedback,
                }
            )

        raw_top5_ranked = sorted(final_scores.items(), key=lambda x: x[1], reverse=True)[:5]
        top5_raw: List[Dict[str, float]] = []
        for major, score in raw_top5_ranked:
            top5_raw.append(
                {
                    "nganh": major,
                    "diem_tho": round(score, 6),
                    "score_final": round(score, 6),
                    "diem_model": round(model_scores.get(major, 0.0), 6),
                    "diem_tieu_chi": round(criteria_scores.get(major, 0.0), 6),
                    "phan_hoc_may": round(ml_dict.get(major, 0.0), 6),
                    "phan_noi_dung": round(content_dict.get(major, 0.0), 6),
                    "rule_boost": round(rule_boosts.get(major, 0.0), 6),
                }
            )

        reasons = [
            f"Điểm cuối mỗi ngành = {int(MODEL_BLEND_WEIGHT * 100)}% điểm mô hình + {int(CRITERIA_BLEND_WEIGHT * 100)}% điểm tiêu chí minh bạch theo 8 trường nhập.",
            "Điểm mô hình gồm: xác suất học máy + tương đồng nội dung + điều chỉnh rule nhẹ.",
            "Điểm tiêu chí minh bạch gồm: sở thích, môn học, kỹ năng, tính cách, môi trường, mục tiêu, mô tả bản thân, định hướng tương lai.",
        ]

        overall_feedback = (
            top3[0]["feedback"]
            if top3
            else "He thong chua du du lieu de tao nhan xet chi tiet cho ket qua nay."
        )

        return {
            "top_3": top3,
            "top_5_diem_tho": top5_raw,
            "giai_thich": reasons,
            "feedback": overall_feedback,
            "cong_thuc": {
                "hoc_may": f"{int(self.weight_rf * 100)}% {self.model_name} + {int(self.weight_cosine * 100)}% cosine (+rule nhe)",
                "noi_dung": "Diem minh bach: 8 truong ho so co trong so co dinh",
                "hien_thi": f"Diem cuoi = {int(MODEL_BLEND_WEIGHT * 100)}% model_score + {int(CRITERIA_BLEND_WEIGHT * 100)}% criteria_score; score_relative chi de so sanh trong cung mot luot.",
            },
        }


def load_predictor() -> Predictor:
    required_files = [
        MODEL_RF_PATH,
        MODEL_OHE_PATH,
        MODEL_TFIDF_PATH,
        MODEL_MAJORS_PATH,
    ]
    missing = [str(f.name) for f in required_files if not f.exists()]
    if missing:
        raise FileNotFoundError(
            "Thieu model: " + ", ".join(missing) + ". Hay chay 'python train_model.py' truoc."
        )
    return Predictor()
